// Definição dos pinos:
const int pinoSensor = A0;      // Sensor de Gás
const int ledVerde = 2;         // 
const int ledVermelho = 3;      // 
const int ledAmarelo = 5;       // 
const int pinoBuzzer = 6;       // 

// Limite
const int limiteBaixo = 487;    //
const int limiteAlto = 600;     //

void setup() {
  //
  pinMode(ledVerde, OUTPUT);
  pinMode(ledAmarelo, OUTPUT);
  pinMode(ledVermelho, OUTPUT);
  pinMode(pinoBuzzer, OUTPUT);
  
  // 
  pinMode(pinoSensor, INPUT);
  
  Serial.begin(9600);
  Serial.println("Sistema de Monitoramento Ativo!");
}

void loop() {
  int valorLido = analogRead(pinoSensor);
  
  Serial.print("Nivel de Fumaca: ");
  Serial.println(valorLido);

  // 
  if (valorLido > limiteAlto) {
    digitalWrite(ledVerde, LOW);
    digitalWrite(ledAmarelo, LOW);
    
    digitalWrite(ledVermelho, HIGH);
    tone(pinoBuzzer, 1300); // Som agudo de perigo
    delay(150);
    
    digitalWrite(ledVermelho, LOW);
    noTone(pinoBuzzer);
    delay(150);
  } 
  //
  else if (valorLido > limiteBaixo) {
    digitalWrite(ledVerde, LOW);
    digitalWrite(ledVermelho, LOW);
    
    digitalWrite(ledAmarelo, HIGH);
    tone(pinoBuzzer, 800); //
    delay(300);
    
    digitalWrite(ledAmarelo, LOW);
    noTone(pinoBuzzer);
    delay(300);
  } 
  //
  else {
    digitalWrite(ledVerde, HIGH);
    digitalWrite(ledAmarelo, LOW);
    digitalWrite(ledVermelho, LOW);
    noTone(pinoBuzzer); // Buzzer em silêncio
    delay(100); 
  }
}
